# Validated at runtime by ~/lib/env (see src/lib/env.ts). Required unless noted.
DATABASE_URL="postgresql://cb:cb@localhost:5432/linear"

# App origin (auth callbacks, tRPC base URL). Default http://localhost:3000
APPLICATION_URL="http://localhost:3000"

# Better Auth (https://www.better-auth.com/docs/installation)
BETTER_AUTH_SECRET=""  # min 32 chars, e.g. openssl rand -base64 32

# Google OAuth (optional; for "Continue with Google")
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""